{
  "name": "nodejs-ecommerce",
  "version": "1.0.0",
  "description": "Backend Node.js + Express para CoffeeEcommerce",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "set NODE_ENV=development&& ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:prod": "set NODE_ENV=production&& ts-node-dev --respawn --transpile-only src/index.ts",
    "db:bootstrap": "npm run build && node dist/scripts/bootstrapDatabases.js",
    "build": "tsc",
    "build:dev": "set NODE_ENV=development&& tsc",
    "build:prod": "set NODE_ENV=production&& tsc",
    "start": "set NODE_ENV=production&& node dist/index.js",
    "start:dev": "set NODE_ENV=development&& node dist/index.js",
    "start:prod": "set NODE_ENV=production&& node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
